# Backend
LLM_PROVIDER=openai
OPENAI_BASE_URL=
OPENAI_API_KEY=

LLM_FAST_MODEL=
LLM_STRONG_MODEL=
LLM_DEFAULT_MODEL=

LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=60

LLM_PLANNING_ENABLED=true
QUERY_SPEC_PLANNING_ENABLED=true

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Frontend build-time API URL.
# Browser reaches frontend on localhost:8080 and nginx proxies /api to backend.
VITE_API_BASE_URL=http://localhost:8080
VITE_API_RUN_PATH=/api/v1/query
VITE_API_PREVIEW_PATH=/api/v1/planner/intent
